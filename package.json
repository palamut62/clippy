{
  "name": "clippy",
  "version": "1.0.0",
  "description": "Lightweight clipboard manager for Windows",
  "main": "src/main/main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.clippy.app",
    "productName": "Clippy",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
